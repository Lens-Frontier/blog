{
  "name": "blog",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.12.3",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "clean:astro": "rm -rf .astro node_modules/.astro dist",
    "build": "astro build",
    "check:markdown": "markdownlint-cli2",
    "check:content": "node scripts/check-content.mjs",
    "check:sensitive": "node scripts/check-sensitive-content.mjs",
    "check:assets": "node scripts/check-assets.mjs",
    "check:types": "astro check",
    "check:dist": "node scripts/check-dist.mjs",
    "check:worker": "node --check workers/pageviews/worker.js",
    "check:analytics": "node scripts/check-analytics-smoke.mjs",
    "check:syntax": "pnpm check:types && pnpm check:worker",
    "check:quality": "pnpm check:markdown && pnpm check:content && pnpm check:sensitive && pnpm check:assets && pnpm images:check && pnpm check:analytics && pnpm clean:astro && pnpm build && pnpm check:dist",
    "images:check": "node scripts/optimize-images.mjs --check",
    "images:optimize": "node scripts/optimize-images.mjs --write",
    "check": "pnpm check:syntax && pnpm check:quality",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "cheerio": "^1.2.0",
    "markdownlint-cli2": "^0.22.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0"
  }
}
