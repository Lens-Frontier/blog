{
  "name": "blog",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.12.3",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "clean:astro": "rm -rf .astro node_modules/.astro dist",
    "build": "astro build",
    "check:assets": "node scripts/check-assets.mjs",
    "images:check": "node scripts/optimize-images.mjs --check",
    "images:optimize": "node scripts/optimize-images.mjs --write",
    "check": "pnpm check:assets && pnpm images:check && pnpm clean:astro && pnpm build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.3"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
