---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EntryRow from '../components/EntryRow.astro';
import { byDateDesc, path } from '../lib/site';

const papers = (await getCollection('papers')).filter((entry) => !entry.data.draft).sort(byDateDesc);
const benchmarks = (await getCollection('benchmarks')).filter((entry) => !entry.data.draft).sort(byDateDesc);
const opinions = (await getCollection('opinions')).filter((entry) => !entry.data.draft).sort(byDateDesc);
const latest = [...papers, ...benchmarks, ...opinions]
	.sort(byDateDesc)
	.slice(0, 5)
	.map((entry) => ({
		entry,
		collection:
			papers.includes(entry as any)
				? 'papers'
				: benchmarks.includes(entry as any)
					? 'benchmarks'
					: 'opinions',
	}));

const channels = [
	{
		label: 'Paper Notes',
		count: papers.length,
		href: path('/papers/'),
		description: '平时阅读分享的论文沉淀。',
	},
	{
		label: 'Opinions',
		count: opinions.length,
		href: path('/opinions/'),
		description: '围绕 benchmark 的浅薄观点。',
	},
	{
		label: 'Benchmarks',
		count: benchmarks.length,
		href: path('/benchmarks/'),
		description: '评测协议、数据集和榜单语境。',
	},
];
---

<BaseLayout>
	<section class="hero">
		<div>
			<p class="eyebrow">papers benchmarks opinions</p>
			<h1>把阅读分享沉淀下来，输出一些浅薄的观点。</h1>
			<p>
				Lens Frontier 用来沉淀大家平时阅读分享的论文，也记录一些围绕 benchmark、evaluation 和真实任务的个人观察。观点可以浅，但最好说清楚证据、上下文和判断边界。
			</p>
		</div>
		<aside class="signal-panel" aria-label="Content channels">
			<h2>Channels</h2>
			<nav class="channel-list">
				{channels.map((channel) => (
					<a class="channel-item" href={channel.href}>
						<span>
							<strong>{channel.label}</strong>
							<small>{channel.description}</small>
						</span>
						<em>{channel.count}</em>
					</a>
				))}
			</nav>
		</aside>
	</section>

	<section class="section-grid">
		<div>
			<div class="section-head">
				<h2>Latest Writing</h2>
				<a href={path('/timeline/')}>timeline</a>
			</div>
			<div class="entry-list">
				{latest.length ? (
					latest.map(({ entry, collection }) => <EntryRow entry={entry} collection={collection as any} />)
				) : (
					<div class="empty-state">
						<p>No notes yet.</p>
						<span>第一篇论文分享、观点文章或 benchmark 观察会出现在这里。</span>
					</div>
				)}
			</div>
		</div>
		<aside class="side-rail">
			<div class="note-box">
				<h2>Editorial Scope</h2>
				<p>这里欢迎不同作者的阅读视角、观点分歧和技术判断。文章不需要给出终局结论，但需要说明证据和边界。</p>
			</div>
			<div class="note-box">
				<h2>House Style</h2>
				<p>主要围绕 benchmark 和 evaluation：观点可以浅一点，证据要多一点；少一点榜单口号，多一点上下文。</p>
			</div>
		</aside>
	</section>
</BaseLayout>
