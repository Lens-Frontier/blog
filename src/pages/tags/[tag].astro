---
import { getCollection } from 'astro:content';
import RedirectLayout from '../../layouts/RedirectLayout.astro';

export async function getStaticPaths() {
	const collectionNames = ['papers', 'benchmarks', 'opinions'] as const;
	const allEntries = await Promise.all(collectionNames.map((name) => getCollection(name)));
	const tags = [
		...new Set(
			allEntries
				.flat()
				.filter((entry) => !entry.data.draft && entry.data.lang === 'zh')
				.flatMap((entry) => entry.data.tags ?? []),
		),
	];
	return tags.map((tag) => ({ params: { tag }, props: { tag } }));
}

const { tag } = Astro.props;
---

<RedirectLayout to={`/zh/tags/${encodeURIComponent(tag)}/`} title={`Tag: ${tag}`} />
