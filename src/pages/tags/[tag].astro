---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryRow from '../../components/EntryRow.astro';
import { byDateDesc } from '../../lib/site';

export async function getStaticPaths() {
	const collectionNames = ['papers', 'benchmarks', 'opinions'] as const;
	const allEntries = await Promise.all(collectionNames.map((name) => getCollection(name)));
	const tags = [...new Set(allEntries.flat().flatMap((entry) => entry.data.tags ?? []))];
	return tags.map((tag) => ({ params: { tag }, props: { tag } }));
}

const { tag } = Astro.props;
const collectionNames = ['papers', 'benchmarks', 'opinions'] as const;
const entriesByCollection = await Promise.all(
	collectionNames.map(async (collection) => ({
		collection,
		entries: (await getCollection(collection)).filter((entry) => entry.data.tags?.includes(tag)),
	})),
);
const entries = entriesByCollection
	.flatMap(({ collection, entries }) => entries.map((entry) => ({ collection, entry })))
	.sort((a, b) => byDateDesc(a.entry, b.entry));
---

<BaseLayout title={`Tag: ${tag}`} description={`标签 ${tag} 下的内容。`}>
	<header class="page-title">
		<div>
			<p class="eyebrow">tag</p>
			<h1>{tag}</h1>
		</div>
		<p>{entries.length} 篇相关内容。</p>
	</header>
	<section class="listing">
		<div class="entry-list">
			{entries.map(({ entry, collection }) => (
				<EntryRow entry={entry} collection={collection} label={collection.slice(0, -1)} />
			))}
		</div>
	</section>
</BaseLayout>
