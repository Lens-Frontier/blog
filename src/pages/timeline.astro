---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EntryRow from '../components/EntryRow.astro';
import { byDateDesc } from '../lib/site';

const papers = (await getCollection('papers'))
	.filter((entry) => !entry.data.draft)
	.map((entry) => ({ entry, collection: 'papers' as const, label: 'paper' }));
const benchmarks = (await getCollection('benchmarks'))
	.filter((entry) => !entry.data.draft)
	.map((entry) => ({ entry, collection: 'benchmarks' as const, label: 'benchmark' }));
const opinions = (await getCollection('opinions'))
	.filter((entry) => !entry.data.draft)
	.map((entry) => ({ entry, collection: 'opinions' as const, label: 'opinion' }));

const entries = [...papers, ...benchmarks, ...opinions].sort((a, b) => byDateDesc(a.entry, b.entry));
---

<BaseLayout title="Timeline" description="全部论文分享、观点文章和 benchmark 观察的时间线。">
	<section class="page-title">
		<div>
			<p class="eyebrow">all writing</p>
			<h1>Timeline</h1>
		</div>
		<p>按时间汇总平时阅读分享的论文、观点文章和 benchmark 观察，方便顺着一条想法从阅读、质疑到判断往回看。</p>
	</section>

	<section class="listing">
		<div class="entry-list">
			{entries.length ? (
				entries.map(({ entry, collection, label }) => (
					<EntryRow entry={entry} collection={collection} label={label} />
				))
			) : (
				<div class="empty-state">
					<p>No writing yet.</p>
					<span>第一篇论文分享、观点文章或 benchmark 观察会出现在这里。</span>
				</div>
			)}
		</div>
	</section>
</BaseLayout>
