---
import { resolveAuthors, type AuthorInput } from '../data/authors';
import { path } from '../lib/site';

interface Props {
	authors?: AuthorInput[];
	compact?: boolean;
}

const { authors: authorInputs = [], compact = false } = Astro.props;
const authors = resolveAuthors(authorInputs);

function avatarUrl(author: AuthorInput) {
	if (author.avatar?.startsWith('http')) return author.avatar;
	if (author.avatar) return path(author.avatar);
	if (author.github) return `https://github.com/${author.github}.png?size=96`;
	return undefined;
}

function authorUrl(author: AuthorInput) {
	return author.url ?? (author.github ? `https://github.com/${author.github}` : undefined);
}

function authorName(author: AuthorInput) {
	return author.name ?? (author.github ? `@${author.github}` : 'Unknown author');
}
---

{authors.length ? (
	<ul class:list={['authors', compact && 'authors--compact']} aria-label="Authors">
		{authors.map((author) => {
			const href = authorUrl(author);
			const avatar = avatarUrl(author);
			const name = authorName(author);
			return (
				<li>
					{avatar ? <img src={avatar} alt={`${name} avatar`} loading="lazy" /> : null}
					<span>
						{href ? (
							<a class="author-name" href={href} target="_blank" rel="noreferrer">
								<strong>{name}</strong>
							</a>
						) : (
							<strong>{name}</strong>
						)}
						{author.name && author.github ? (
							<a href={href} target="_blank" rel="noreferrer">@{author.github}</a>
						) : href && !author.github ? (
							<a href={href} target="_blank" rel="noreferrer">profile</a>
						) : null}
					</span>
				</li>
			);
		})}
	</ul>
) : null}
