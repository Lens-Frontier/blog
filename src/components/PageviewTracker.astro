---
interface Props {
	articleId: string;
}

const { articleId } = Astro.props;
const endpoint = import.meta.env.PUBLIC_PAGEVIEW_ENDPOINT;
const siteId = import.meta.env.PUBLIC_PAGEVIEW_SITE_ID ?? 'lens-frontier';
---

{
	endpoint ? (
		<script is:inline define:vars={{ articleId, endpoint, siteId }}>
			(() => {
				if (!endpoint) return;

				const doNotTrack = navigator.doNotTrack === '1' || window.doNotTrack === '1';
				if (doNotTrack) return;

				const payload = JSON.stringify({
					siteId,
					articleId,
					path: window.location.pathname,
				});

				fetch(endpoint, {
					method: 'POST',
					body: payload,
					headers: { 'Content-Type': 'application/json' },
					keepalive: true,
					credentials: 'omit',
				})
					.then((response) => {
						if (!response.ok) return null;
						return response.json().catch(() => null);
					})
					.then((data) => {
						if (!data) return;
						window.__lensFrontierRecordedPageviews ??= new Map();
						window.__lensFrontierRecordedPageviews.set(articleId, Number(data.viewCount || 0));
						window.dispatchEvent(
							new CustomEvent('lens-frontier:pageview-recorded', { detail: { articleId, viewCount: data.viewCount } }),
						);
					})
					.catch(() => {});
			})();
		</script>
	) : null
}
