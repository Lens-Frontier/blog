---
interface Props {
	articleId: string;
}

const { articleId } = Astro.props;
const endpoint = import.meta.env.PUBLIC_PAGEVIEW_ENDPOINT;
const siteId = import.meta.env.PUBLIC_PAGEVIEW_SITE_ID ?? 'lens-frontier';
---

{
	endpoint ? (
		<script is:inline define:vars={{ articleId, endpoint, siteId }}>
			(() => {
				if (!endpoint) return;

				const doNotTrack = navigator.doNotTrack === '1' || window.doNotTrack === '1';
				if (doNotTrack) return;

				const payload = JSON.stringify({
					siteId,
					articleId,
					path: window.location.pathname,
				});
				let posted = false;

				const postPageview = (preferBeacon = false) => {
					if (posted) return;
					posted = true;

					if (preferBeacon && 'sendBeacon' in navigator) {
						const blob = new Blob([payload], { type: 'text/plain;charset=UTF-8' });
						if (navigator.sendBeacon(endpoint, blob)) return;
					}

					const controller = typeof AbortController !== 'undefined' ? new AbortController() : null;
					const timeout = controller ? window.setTimeout(() => controller.abort(), 3500) : null;

					fetch(endpoint, {
						method: 'POST',
						body: payload,
						headers: { 'Content-Type': 'application/json' },
						keepalive: true,
						credentials: 'omit',
						signal: controller?.signal,
					})
						.then((response) => {
							if (!response.ok) return null;
							return response.json().catch(() => null);
						})
						.then((data) => {
							if (!data) return;
							window.__lensFrontierRecordedPageviews ??= new Map();
							window.__lensFrontierRecordedPageviews.set(articleId, Number(data.viewCount || 0));
							window.dispatchEvent(
								new CustomEvent('lens-frontier:pageview-recorded', { detail: { articleId, viewCount: data.viewCount } }),
							);
						})
						.catch(() => {})
						.finally(() => {
							if (timeout) window.clearTimeout(timeout);
						});
				};

				const schedulePageview = () => {
					if ('requestIdleCallback' in window) {
						window.requestIdleCallback(() => postPageview(), { timeout: 2000 });
						return;
					}
					window.setTimeout(postPageview, 800);
				};
				const flushPageview = () => postPageview(true);

				if (document.readyState === 'complete') schedulePageview();
				else window.addEventListener('load', schedulePageview, { once: true });
				window.addEventListener('pagehide', flushPageview, { once: true });
				document.addEventListener('visibilitychange', () => {
					if (document.visibilityState === 'hidden') flushPageview();
				});
			})();
		</script>
	) : null
}
