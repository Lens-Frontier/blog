---
interface Props {
	placement?: 'head' | 'body';
}

const { placement = 'head' } = Astro.props;
const containerId = import.meta.env.PUBLIC_GTM_CONTAINER_ID;
const dataLayerName = import.meta.env.PUBLIC_GTM_DATA_LAYER ?? 'dataLayer';
const enabled = Boolean(containerId) && import.meta.env.PUBLIC_GTM_ENABLED !== 'false';
const query = `id=${encodeURIComponent(containerId ?? '')}${
	dataLayerName !== 'dataLayer' ? `&l=${encodeURIComponent(dataLayerName)}` : ''
}`;
---

{
	enabled && placement === 'head' ? (
		<script is:inline define:vars={{ containerId, dataLayerName }}>
			(() => {
				const doNotTrack = navigator.doNotTrack === '1' || window.doNotTrack === '1';
				if (doNotTrack) return;

				(function (w, d, s, l, i) {
					w[l] = w[l] || [];
					w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
					const firstScript = d.getElementsByTagName(s)[0];
					const tag = d.createElement(s);
					const dataLayerQuery = l !== 'dataLayer' ? `&l=${encodeURIComponent(l)}` : '';
					tag.async = true;
					tag.src = `https://www.googletagmanager.com/gtm.js?id=${encodeURIComponent(i)}${dataLayerQuery}`;
					firstScript.parentNode.insertBefore(tag, firstScript);
				})(window, document, 'script', dataLayerName, containerId);
			})();
		</script>
	) : enabled && placement === 'body' ? (
		<noscript>
			<iframe
				src={`https://www.googletagmanager.com/ns.html?${query}`}
				height="0"
				width="0"
				style="display:none;visibility:hidden"
			/>
		</noscript>
	) : null
}
