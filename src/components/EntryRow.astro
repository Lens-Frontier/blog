---
import Authors from './Authors.astro';
import { entryPath, formatDate, languageFrom, tagPath } from '../lib/site';
import type { Language } from '../lib/site';

interface Props {
	entry: any;
	collection: 'papers' | 'benchmarks' | 'opinions';
	label?: string;
	lang?: Language;
}

const { entry, collection, label, lang: inputLang } = Astro.props;
const lang = languageFrom(inputLang ?? entry.data.lang);
const data = entry.data;
const href = entryPath(collection, entry.id, lang);
const meta = [
	formatDate(data.date, lang),
	data.venue,
	data.area,
	data.metric,
	data.status,
].filter(Boolean);
---

<article class="entry-row">
	<div class="entry-row__rail">
		<span>{label ?? collection}</span>
	</div>
	<div class="entry-row__body">
		<a class="entry-title" href={href}>{data.title}</a>
		<p>{data.summary}</p>
		<div class="entry-meta">
			{meta.map((item) => <span>{item}</span>)}
		</div>
		<Authors authors={data.authors} compact />
		{data.tags?.length ? (
			<div class="tag-list" aria-label="Tags">
				{data.tags.slice(0, 5).map((tag: string) => (
					<a href={tagPath(tag, lang)}>{tag}</a>
				))}
			</div>
		) : null}
	</div>
</article>
