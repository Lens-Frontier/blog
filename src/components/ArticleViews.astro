---
import { languageFrom, ui } from '../lib/site';
import type { Language } from '../lib/site';

interface Props {
	articleId: string;
	lang?: Language;
}

const { articleId, lang: inputLang } = Astro.props;
const lang = languageFrom(inputLang);
const labels = ui[lang].article;
const pageviewEndpoint = import.meta.env.PUBLIC_PAGEVIEW_ENDPOINT;
const countEndpoint = import.meta.env.PUBLIC_PAGEVIEW_COUNT_ENDPOINT ?? deriveCountEndpoint(pageviewEndpoint);
const siteId = import.meta.env.PUBLIC_PAGEVIEW_SITE_ID ?? 'lens-frontier';

function deriveCountEndpoint(endpoint?: string) {
	if (!endpoint) return undefined;

	try {
		const url = new URL(endpoint);
		url.pathname = url.pathname.replace(/\/pageview\/?$/, '/views');
		return url.toString();
	} catch {
		return endpoint.replace(/\/pageview\/?$/, '/views');
	}
}
---

{
	countEndpoint ? (
		<span
			class="article-views"
			data-article-views
			data-loading-label={labels.viewsLoading}
			aria-label={`${labels.views}: ${labels.viewsLoading}`}
		>
			<span>{labels.views}</span>
			<strong data-view-count>--</strong>
		</span>
		<script is:inline define:vars={{ articleId, countEndpoint, lang, siteId }}>
			(() => {
				const target = document.querySelector('[data-article-views]');
				const value = target?.querySelector('[data-view-count]');
				if (!target || !value) return;

				const formatter = new Intl.NumberFormat(lang === 'zh' ? 'zh-CN' : 'en-US');
				const url = new URL(countEndpoint, window.location.origin);
				url.searchParams.set('siteId', siteId);
				url.searchParams.set('articleId', articleId);
				let refreshRequestId = 0;
				let latestCount = null;
				let fallbackScheduled = false;

				const renderViewCount = (rawCount) => {
					const count = Number(rawCount || 0);
					if (latestCount !== null && count < latestCount) return;
					latestCount = count;
					value.textContent = formatter.format(count);
					target.hidden = false;
					target.setAttribute('aria-label', `${target.firstElementChild?.textContent || 'Views'}: ${count}`);
				};

				const refreshViewCount = () => {
					const requestId = ++refreshRequestId;
					const controller = typeof AbortController !== 'undefined' ? new AbortController() : null;
					const timeout = controller ? window.setTimeout(() => controller.abort(), 2500) : null;

					fetch(url.toString(), { credentials: 'omit', cache: 'no-store', signal: controller?.signal })
						.then((response) => (response.ok ? response.json() : Promise.reject()))
						.then((data) => {
							if (requestId !== refreshRequestId) return;
							renderViewCount(data.viewCount);
						})
						.catch(() => {
							if (requestId === refreshRequestId && latestCount === null) target.hidden = true;
						})
						.finally(() => {
							if (timeout) window.clearTimeout(timeout);
						});
				};

				const scheduleFallbackRead = () => {
					if (fallbackScheduled || latestCount !== null) return;
					fallbackScheduled = true;
					const read = () => {
						if (latestCount === null) refreshViewCount();
					};
					if ('requestIdleCallback' in window) {
						window.requestIdleCallback(read, { timeout: 3000 });
						return;
					}
					window.setTimeout(read, 1600);
				};

				window.addEventListener('lens-frontier:pageview-recorded', (event) => {
					if (event.detail?.articleId !== articleId) return;
					if (Number.isFinite(Number(event.detail.viewCount))) renderViewCount(event.detail.viewCount);
					else refreshViewCount();
				});
				if (window.__lensFrontierRecordedPageviews?.has(articleId)) {
					renderViewCount(window.__lensFrontierRecordedPageviews.get(articleId));
				} else if (document.readyState === 'complete') {
					scheduleFallbackRead();
				} else {
					window.addEventListener('load', scheduleFallbackRead, { once: true });
				}
			})();
		</script>
	) : null
}
