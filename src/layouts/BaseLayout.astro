---
import '../styles/global.css';
import AnalyticsEvents from '../components/AnalyticsEvents.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import { languageFrom, languages, localizedPath, path, repositoryUrl, siteFor, ui } from '../lib/site';
import type { Language } from '../lib/site';

type AlternatePath = string | Partial<Record<Language, string>>;

interface Props {
	title?: string;
	description?: string;
	lang?: Language;
	alternatePath?: AlternatePath;
}

const lang = languageFrom(Astro.props.lang);
const labels = ui[lang];
const site = siteFor(lang);
const { title = site.title, description = site.description } = Astro.props;
const alternatePath = Astro.props.alternatePath ?? '/';
const pageTitle = title === site.title ? title : `${title} - ${site.title}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://example.com');
const navItems = [
	{ href: localizedPath(lang, '/papers/'), label: labels.nav.papers },
	{ href: localizedPath(lang, '/benchmarks/'), label: labels.nav.benchmarks },
	{ href: localizedPath(lang, '/opinions/'), label: labels.nav.opinions },
	{ href: localizedPath(lang, '/tags/'), label: labels.nav.tags },
];

function alternatePathFor(targetLang: Language) {
	if (typeof alternatePath === 'string') return alternatePath;
	return alternatePath[targetLang] ?? alternatePath[lang] ?? '/';
}
---

<!doctype html>
<html lang={site.htmlLang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<GoogleAnalytics />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		{languages.map((item) => (
			<link rel="alternate" hreflang={siteFor(item).htmlLang} href={localizedPath(item, alternatePathFor(item))} />
		))}
		<link rel="icon" type="image/svg+xml" href={path('/favicon.svg')} />
	</head>
	<body>
		<div class="shell">
			<header class="site-header">
				<a class="brand" href={localizedPath(lang, '/')}>
					<span class="brand-mark">LF</span>
					<span>
						<strong>Lens Frontier</strong>
						<small>{labels.brandTagline}</small>
					</span>
				</a>
				<div class="header-actions">
					<nav class="nav" aria-label="Primary navigation">
						{navItems.map((item) => <a href={item.href}>{item.label}</a>)}
					</nav>
					<nav class="lang-switch" aria-label="Language switcher">
						{languages.map((item) => (
							<a
								href={localizedPath(item, alternatePathFor(item))}
								aria-current={item === lang ? 'true' : undefined}
							>
								{labels.languageNames[item]}
							</a>
						))}
					</nav>
				</div>
			</header>
			<main>
				<slot />
			</main>
			<footer class="site-footer">
				<div>
					<span>Lens Frontier</span>
					<span>{labels.footer.line}</span>
				</div>
				<nav class="footer-links" aria-label="Secondary navigation">
					<a href={localizedPath(lang, '/timeline/')}>{labels.footer.timeline}</a>
					<a href={localizedPath(lang, '/about/')}>{labels.footer.about}</a>
					<a href={localizedPath(lang, '/rss.xml')}>{labels.footer.rss}</a>
					<a href={repositoryUrl} target="_blank" rel="noreferrer">{labels.footer.github}</a>
				</nav>
			</footer>
		</div>
		<AnalyticsEvents lang={lang} />
	</body>
</html>
