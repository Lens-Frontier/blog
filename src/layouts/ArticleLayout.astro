---
import BaseLayout from './BaseLayout.astro';
import ArticleViews from '../components/ArticleViews.astro';
import Authors from '../components/Authors.astro';
import PageviewTracker from '../components/PageviewTracker.astro';
import SpecTable from '../components/SpecTable.astro';
import { translatedEntry, type CollectionName } from '../lib/content';
import { formatDate, languageFrom, languages, tagPath, ui } from '../lib/site';
import type { Language } from '../lib/site';

interface Props {
	entry: any;
	type: 'paper' | 'benchmark' | 'opinion';
}

const { entry, type } = Astro.props;
const data = entry.data;
const lang = languageFrom(data.lang);
const labels = ui[lang];
const collection: CollectionName = type === 'paper' ? 'papers' : type === 'benchmark' ? 'benchmarks' : 'opinions';
const articleId = `${collection}/${entry.id}`;
const alternatePath = Object.fromEntries(
	await Promise.all(
		languages.map(async (targetLang) => {
			if (targetLang === lang) return [targetLang, `/${collection}/${entry.id}/`];
			const translated = await translatedEntry(collection, data.translationKey, targetLang);
			return [targetLang, translated ? `/${collection}/${translated.id}/` : `/${collection}/`];
		}),
	),
) as Partial<Record<Language, string>>;
type SpecItem = [string, string | string[] | undefined];
const spec: SpecItem[] =
	type === 'paper'
		? [
				[labels.article.spec.date, formatDate(data.date, lang)],
				[labels.article.spec.paperAuthors, data.paperAuthors],
				[labels.article.spec.venue, data.venue],
				[labels.article.spec.benchmarks, data.benchmarks],
				[labels.article.spec.tasks, data.tasks],
				[labels.article.spec.status, data.status],
			]
		: type === 'benchmark'
			? [
					[labels.article.spec.date, formatDate(data.date, lang)],
					[labels.article.spec.area, data.area],
					[labels.article.spec.metric, data.metric],
					[labels.article.spec.version, data.version],
					[labels.article.spec.risk, data.risk],
					[labels.article.spec.status, data.status],
				]
			: [
					[labels.article.spec.date, formatDate(data.date, lang)],
					[labels.article.spec.stance, data.stance],
				];
---

<BaseLayout title={data.title} description={data.summary} lang={lang} alternatePath={alternatePath}>
	<article class="article">
		<header class="article-header">
			<p class="eyebrow">{type}</p>
			<h1>{data.title}</h1>
			<p class="dek">{data.summary}</p>
			<div class="article-byline">
				<Authors authors={data.authors} />
				<ArticleViews articleId={articleId} lang={lang} />
			</div>
			<SpecTable items={spec} />
			<div class="article-actions">
				{data.paperUrl ? <a href={data.paperUrl}>{labels.article.paper}</a> : null}
				{data.codeUrl ? <a href={data.codeUrl}>{labels.article.code}</a> : null}
			</div>
			{data.tags?.length ? (
				<div class="tag-list">
					{data.tags.map((tag: string) => <a href={tagPath(tag, lang)}>{tag}</a>)}
				</div>
			) : null}
		</header>
		<div class="article-body">
			<slot />
		</div>
		<PageviewTracker articleId={articleId} />
	</article>
</BaseLayout>
